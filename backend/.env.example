# ---- AItranscriber backend (.env) ----
# Copy this file to: backend/.env
# DO NOT commit backend/.env (it contains secrets)

# Groq (Whisper)
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional override (backend also tries fallbacks)
# GEMINI_MODEL=gemini-2.5-flash

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Recommended: service role key for server-side usage
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Auth/JWT
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Storage
# Default: audio
SUPABASE_AUDIO_BUCKET=audio

# Pinecone (optional: enables semantic search)
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_INDEX=YOUR_PINECONE_INDEX_NAME
